@@ -0,0 +1,256 @@
+"""
+MCP (Model Context Protocol) client for Tableau integration.
+This module provides a client to communicate with the Tableau MCP server.
+"""
+
+import requests
+import json
+from typing import Dict, Any, Optional
+import os
+
+
+class TableauMCPClient:
+    """Client for communicating with the Tableau MCP server."""
+
+    def __init__(self, mcp_server_url: Optional[str] = None):
+        """
+        Initialize the MCP client.
+
+        Args:
+            mcp_server_url: URL of the MCP server. If None, uses environment variable MCP_SERVER_URL.
+        """
+        self.mcp_server_url = mcp_server_url or os.getenv("MCP_SERVER_URL", "https://allison-mcp-server.up.railway.app/tableau-mcp")
+        if not self.mcp_server_url.endswith('/'):
+            self.mcp_server_url += '/'
+
+    def _parse_sse_response(self, sse_text: str) -> Dict[str, Any]:
+        """
+        Parse Server-Sent Events (SSE) response from MCP server.
+
+        Args:
+            sse_text: The SSE response text
+
+        Returns:
+            Parsed JSON data from the SSE response
+        """
+        lines = sse_text.strip().split('\n')
+        data_lines = []
+
+        for line in lines:
+            if line.startswith('data: '):
+                data_lines.append(line[6:])  # Remove 'data: ' prefix
+
+        if not data_lines:
+            raise RuntimeError("No data found in SSE response")
+
+        # Try to parse each data line as separate JSON objects
+        # and return the last one (which should be the final result)
+        for json_data in data_lines:
+            try:
+                result = json.loads(json_data)
+                # If this is a valid JSON-RPC response, return it
+                if 'jsonrpc' in result and 'id' in result:
+                    return result
+            except json.JSONDecodeError:
+                continue
+
+        # If no valid JSON-RPC response found, try to parse all data as one JSON
+        try:
+            json_data = '\n'.join(data_lines)
+            return json.loads(json_data)
+        except json.JSONDecodeError as e:
+            raise RuntimeError(f"Failed to parse SSE response as JSON: {e}")
+
+    def query_datasource(self, datasource_luid: str, query: Dict[str, Any]) -> Dict[str, Any]:
+        """
+        Query a Tableau datasource through the MCP server using JSON-RPC 2.0.
+
+        Args:
+            datasource_luid: The LUID of the datasource to query
+            query: The VDS query payload
+
+        Returns:
+            The query results from the MCP server
+        """
+        # MCP uses JSON-RPC 2.0 protocol
+        jsonrpc_payload = {
+            "jsonrpc": "2.0",
+            "method": "tools/call",
+            "params": {
+                "name": "query-datasource",
+                "arguments": {
+                    "datasourceLuid": datasource_luid,
+                    "query": query
+                }
+            },
+            "id": 1
+        }
+
+        response = requests.post(
+            self.mcp_server_url,
+            json=jsonrpc_payload,
+            headers={
+                'Content-Type': 'application/json',
+                'Accept': 'application/json, text/event-stream'
+            }
+        )
+
+        if response.status_code == 200:
+            # Parse Server-Sent Events (SSE) format
+            result = self._parse_sse_response(response.text)
+            if 'error' in result:
+                raise RuntimeError(f"MCP server error: {result['error']}")
+            return result.get('result', {})
+        else:
+            error_message = (
+                f"Failed to query data source via Tableau MCP server. "
+                f"Status code: {response.status_code}. Response: {response.text}"
+            )
+            raise RuntimeError(error_message)
+
+    def get_metadata(self, datasource_luid: str) -> Dict[str, Any]:
+        """
+        Get metadata for a Tableau datasource through the MCP server using JSON-RPC 2.0.
+
+        Args:
+            datasource_luid: The LUID of the datasource
+
+        Returns:
+            The metadata from the MCP server
+        """
+        # MCP uses JSON-RPC 2.0 protocol
+        jsonrpc_payload = {
+            "jsonrpc": "2.0",
+            "method": "tools/call",
+            "params": {
+                "name": "read-metadata",
+                "arguments": {
+                    "datasourceLuid": datasource_luid
+                }
+            },
+            "id": 2
+        }
+
+        response = requests.post(
+            self.mcp_server_url,
+            json=jsonrpc_payload,
+            headers={
+                'Content-Type': 'application/json',
+                'Accept': 'application/json, text/event-stream'
+            }
+        )
+
+        if response.status_code == 200:
+            # Parse Server-Sent Events (SSE) format
+            result = self._parse_sse_response(response.text)
+            if 'error' in result:
+                raise RuntimeError(f"MCP server error: {result['error']}")
+            return result.get('result', {})
+        else:
+            error_message = (
+                f"Failed to obtain data source metadata from Tableau MCP server. "
+                f"Status code: {response.status_code}. Response: {response.text}"
+            )
+            raise RuntimeError(error_message)
+
+    def list_datasources(self) -> Dict[str, Any]:
