+#!/usr/bin/env python3
+"""
+Local test script for the Tableau LangChain project with MCP integration.
+This script sets up minimal environment variables and runs the LangGraph server.
+"""
+
+import os
+import sys
+import subprocess
+from pathlib import Path
+
+def set_environment_variables():
+    """Set minimal environment variables needed for the server to start."""
+    env_vars = {
+        # Tableau Configuration (minimal values for testing)
+        'TABLEAU_DOMAIN': 'test-tableau-domain.com',
+        'TABLEAU_SITE': 'test-site',
+        'TABLEAU_JWT_CLIENT_ID': 'test-client-id',
+        'TABLEAU_JWT_SECRET_ID': 'test-secret-id',
+        'TABLEAU_JWT_SECRET': 'test-secret',
+        'TABLEAU_API_VERSION': '3.22',
+        'TABLEAU_USER': 'test-user',
+        'DATASOURCE_LUID': 'test-datasource-luid',
+        
+        # Model Configuration
+        'MODEL_PROVIDER': 'openai',
+        'TOOLING_MODEL': 'gpt-4o-mini',
+        'EMBEDDING_MODEL': 'text-embedding-3-small',
+        
+        # Pinecone Configuration (minimal values)
+        'METRICS_INDEX': 'test-metrics-index',
+        'DATASOURCES_INDEX': 'test-datasources-index',
+        'WORKBOOKS_INDEX': 'test-workbooks-index',
+        'PINECONE_API_KEY': 'test-pinecone-key',
+        
+        # OpenAI Configuration (you'll need to set this)
+        'OPENAI_API_KEY': os.getenv('OPENAI_API_KEY', 'your-openai-key-here'),
+        
+        # MCP Server Configuration (using your Heroku MCP server)
+        'MCP_SERVER_URL': 'https://allison-mcp-server.up.railway.app/tableau-mcp',
+        
+        # Slack Configuration (optional)
+        'SLACK_BOT_TOKEN': 'test-slack-token',
+        'SLACK_APP_TOKEN': 'test-app-token',
+    }
+    
+    # Set environment variables
+    for key, value in env_vars.items():
+        os.environ[key] = value
+        print(f"Set {key}={value}")
+    
+    print("\n✅ Environment variables set successfully!")
+    print("Note: You may need to set OPENAI_API_KEY with a real value for full functionality.")
+
+def run_langgraph_server():
+    """Run the LangGraph server."""
+    print("\n🚀 Starting LangGraph server...")
+    print("The server will be available at:")
+    print("- 🚀 API: http://127.0.0.1:2024")
+    print("- 🎨 Studio UI: https://smith.langchain.com/studio/?baseUrl=http://127.0.0.1:2024")
+    print("- 📚 API Docs: http://127.0.0.1:2024/docs")
+    print("\nPress Ctrl+C to stop the server.\n")
+    
+    try:
+        # Run the langgraph dev command
+        subprocess.run(['langgraph', 'dev'], check=True)
+    except subprocess.CalledProcessError as e:
+        print(f"❌ Error running LangGraph server: {e}")
+        print("Make sure you have langgraph installed: pip install langgraph")
+        sys.exit(1)
+    except KeyboardInterrupt:
+        print("\n👋 Server stopped by user.")
+        sys.exit(0)
+
+def main():
+    """Main function to set up and run the local test."""
+    print("🔧 Setting up environment for local testing...")
+    
+    # Check if we're in the right directory
+    if not Path('langgraph.json').exists():
+        print("❌ Error: langgraph.json not found. Make sure you're in the tableau_langchain directory.")
+        sys.exit(1)
+    
+    # Set environment variables
+    set_environment_variables()
+    
+    # Run the server
+    run_langgraph_server()
+
+if __name__ == "__main__":
+    main()
