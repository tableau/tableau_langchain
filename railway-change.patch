@@ -0,0 +1,92 @@
+"""
+Configuration module for Tableau LangChain integration.
+Handles MCP server configuration and environment variables.
+"""
+
+import os
+from typing import Optional
+
+
+class TableauConfig:
+    """Configuration class for Tableau integration."""
+
+    def __init__(self):
+        """Initialize configuration with environment variables."""
+        self.mcp_server_url = os.getenv(
+            "MCP_SERVER_URL",
+            "https://allison-mcp-server.up.railway.app/tableau-mcp"
+        )
+        self.tableau_domain = os.getenv("TABLEAU_DOMAIN")
+        self.tableau_site = os.getenv("TABLEAU_SITE")
+        self.tableau_api_version = os.getenv("TABLEAU_API_VERSION", "3.20")
+        self.jwt_client_id = os.getenv("JWT_CLIENT_ID")
+        self.jwt_secret_id = os.getenv("JWT_SECRET_ID")
+        self.jwt_secret = os.getenv("JWT_SECRET")
+        self.tableau_user = os.getenv("TABLEAU_USER")
+        self.datasource_luid = os.getenv("DATASOURCE_LUID")
+        self.model_provider = os.getenv("MODEL_PROVIDER", "openai")
+        self.tooling_llm_model = os.getenv("TOOLING_LLM_MODEL", "gpt-4")
+
+    def get_mcp_server_url(self) -> str:
+        """Get the MCP server URL."""
+        return self.mcp_server_url
+
+    def set_mcp_server_url(self, url: str) -> None:
+        """Set the MCP server URL."""
+        self.mcp_server_url = url
+        os.environ["MCP_SERVER_URL"] = url
+
+    def validate_config(self) -> bool:
+        """Validate that required configuration is present."""
+        required_vars = [
+            "MCP_SERVER_URL"
+        ]
+
+        missing_vars = []
+        for var in required_vars:
+            if not os.getenv(var):
+                missing_vars.append(var)
+
+        if missing_vars:
+            print(f"Warning: Missing required environment variables: {', '.join(missing_vars)}")
+            return False
+
+        return True
+
+    def get_tableau_auth_config(self) -> dict:
+        """Get Tableau authentication configuration."""
+        return {
+            "domain": self.tableau_domain,
+            "site": self.tableau_site,
+            "jwt_client_id": self.jwt_client_id,
+            "jwt_secret_id": self.jwt_secret_id,
+            "jwt_secret": self.jwt_secret,
+            "tableau_api_version": self.tableau_api_version,
+            "tableau_user": self.tableau_user
+        }
+
+    def get_model_config(self) -> dict:
+        """Get model configuration."""
+        return {
+            "model_provider": self.model_provider,
+            "tooling_llm_model": self.tooling_llm_model
+        }
+
+
+# Global configuration instance
+config = TableauConfig()
+
+
+def get_mcp_server_url() -> str:
+    """Get the MCP server URL from configuration."""
+    return config.get_mcp_server_url()
+
+
+def set_mcp_server_url(url: str) -> None:
+    """Set the MCP server URL in configuration."""
+    config.set_mcp_server_url(url)
+
+
+def validate_configuration() -> bool:
+    """Validate the current configuration."""
+    return config.validate_config()
